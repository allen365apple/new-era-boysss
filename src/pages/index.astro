---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.intro {
				text-align: center;
				margin-bottom: 3rem;
				padding: 2rem;
				background: linear-gradient(135deg, #f8f9fa, #e9ecef);
				border-radius: 12px;
			}
			.intro h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
				color: rgb(var(--black));
			}
			.intro p {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				aspect-ratio: 2/1;
				object-fit: cover;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0 0 0.25rem;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.2rem;
			}
			.meta {
				display: flex;
				gap: 0.75rem;
				align-items: center;
				flex-wrap: wrap;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.episode-tag {
				background: rgb(var(--accent));
				color: white;
				font-size: 0.75rem;
				padding: 0.15rem 0.5rem;
				border-radius: 4px;
				font-weight: bold;
			}
			.topic-tag {
				background: #e9ecef;
				color: rgb(var(--gray-dark));
				font-size: 0.75rem;
				padding: 0.15rem 0.5rem;
				border-radius: 4px;
			}
			ul li a:hover .title,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<h1>新世紀直男戰士</h1>
				<p>用男性視角重新理解性別議題。每篇文章整理自 Podcast 對談，讓更多人看見這些對話。</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.coverImage && (
										<Image width={720} height={360} src={post.data.coverImage} alt={post.data.title} />
									)}
									<h2 class="title">{post.data.title}</h2>
									<div class="meta">
										<span class="date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										{post.data.episode && (
											<span class="episode-tag">{post.data.episode}</span>
										)}
										{post.data.topics && post.data.topics.slice(0, 2).map(t => (
											<span class="topic-tag">{t}</span>
										))}
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
