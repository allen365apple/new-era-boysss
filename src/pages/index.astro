---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				max-width: 760px;
				margin: 0 auto;
				padding: 5rem 1.25rem 3rem;
				text-align: center;
			}
			.hero .eyebrow {
				display: inline-block;
				background: var(--accent-light);
				color: var(--accent-dark);
				font-size: 0.82rem;
				font-weight: 600;
				padding: 0.3rem 0.9rem;
				border-radius: 999px;
				margin-bottom: 1.25rem;
			}
			.hero h1 {
				font-size: 3rem;
				margin: 0 0 1rem;
			}
			.hero p {
				font-size: 1.15rem;
				color: var(--text-secondary);
				max-width: 560px;
				margin: 0 auto;
			}

			.posts {
				max-width: 760px;
				margin: 0 auto;
				padding: 1rem 1.25rem 5rem;
			}
			.post-card {
				display: grid;
				grid-template-columns: 150px 1fr;
				gap: 1.5rem;
				padding: 1.75rem 0;
				border-top: 1px dashed var(--border);
				align-items: center;
			}
			.post-card.no-thumb {
				grid-template-columns: 1fr;
			}
			.post-card:last-child {
				border-bottom: 1px dashed var(--border);
			}
			.post-card .thumb {
				border-radius: var(--radius);
				overflow: hidden;
				aspect-ratio: 1 / 1;
				background: var(--surface-soft);
			}
			.post-card .thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.3s ease;
			}
			.post-card:hover .thumb img {
				transform: scale(1.04);
			}
			.post-card .body {
				min-width: 0;
			}
			.post-card .tags {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-bottom: 0.5rem;
			}
			.episode-tag {
				background: var(--accent);
				color: #fff;
				font-size: 0.72rem;
				font-weight: 600;
				padding: 0.15rem 0.6rem;
				border-radius: 999px;
			}
			.topic-tag {
				background: var(--accent-light);
				color: var(--accent-dark);
				font-size: 0.72rem;
				font-weight: 500;
				padding: 0.15rem 0.6rem;
				border-radius: 999px;
			}
			.post-card h2 {
				font-size: 1.3rem;
				margin: 0 0 0.4rem;
				color: var(--text-primary);
				transition: color 0.15s ease;
			}
			.post-card a:hover h2 {
				color: var(--accent);
			}
			.post-card .desc {
				color: var(--text-secondary);
				font-size: 0.95rem;
				margin: 0 0 0.5rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-card .date {
				color: var(--text-muted);
				font-size: 0.85rem;
			}
			.post-card a {
				text-decoration: none;
				color: inherit;
			}
			@media (max-width: 640px) {
				.hero {
					padding-top: 3rem;
				}
				.hero h1 {
					font-size: 2.1rem;
				}
				.post-card {
					grid-template-columns: 96px 1fr;
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main style="width: 100%; max-width: 100%; padding: 0;">
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>用男性視角，認真討論性別這件事。每篇文章整理自節目對談，讓更多人看見這些對話。</p>
			</section>

			<section class="posts">
				{
					posts.map((post) => (
						<a href={`/blog/${post.id}/`}>
							<article class={`post-card${post.data.coverImage ? '' : ' no-thumb'}`}>
								{post.data.coverImage && (
									<div class="thumb">
										<Image width={300} height={300} src={post.data.coverImage} alt={post.data.title} />
									</div>
								)}
								<div class="body">
									<div class="tags">
										{post.data.episode && <span class="episode-tag">{post.data.episode}</span>}
										{post.data.topics && post.data.topics.slice(0, 2).map((t) => <span class="topic-tag">{t}</span>)}
									</div>
									<h2>{post.data.title}</h2>
									<p class="desc">{post.data.description}</p>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
							</article>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
