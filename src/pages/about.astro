---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const topics = ['男性特權', '情感腳本', '性別凝視', '身份認同', '在地事件', '多元對話', '聽眾互動'];
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead
			title={`關於節目 — ${SITE_TITLE}`}
			description="《新世紀直男戰士》是一個從男性視角出發，認真討論性別議題的 Podcast。我們相信，男性加入性別對話，是讓社會更平等的重要一步。"
		/>
		<style>
			main {
				max-width: 680px;
			}
			.eyebrow {
				display: inline-block;
				background: var(--accent-light);
				color: var(--accent-dark);
				font-size: 0.82rem;
				font-weight: 600;
				padding: 0.3rem 0.9rem;
				border-radius: 999px;
				margin-bottom: 1rem;
			}
			.subtitle {
				color: var(--text-secondary);
				font-size: 1.15rem;
				margin-bottom: 2.5rem;
			}
			.topic-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin: 1.5rem 0 2.5rem;
			}
			.topic-tag {
				background: var(--surface-soft);
				border: 1px solid var(--border);
				color: var(--text-primary);
				padding: 0.4rem 0.9rem;
				border-radius: 999px;
				font-size: 0.9rem;
			}
			.listen-section {
				margin-top: 2.5rem;
				padding: 1.75rem;
				background: var(--surface-soft);
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
			}
			.listen-section h2 {
				margin-top: 0;
				font-size: 1.15rem;
			}
			.listen-links {
				display: flex;
				gap: 0.6rem;
				flex-wrap: wrap;
				margin-top: 1rem;
			}
			.listen-links a {
				display: inline-flex;
				padding: 0.5rem 1.1rem;
				border-radius: 999px;
				font-weight: 600;
				font-size: 0.85rem;
				color: #fff;
			}
			.btn-soundon { background: #ff6b35; }
			.btn-spotify { background: #1db954; }
			.btn-apple   { background: #a855f7; }
			.btn-kkbox   { background: #009fcc; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<span class="eyebrow">關於節目</span>
			<h1>關於《新世紀直男戰士》</h1>
			<p class="subtitle">用男性視角，認真討論性別這件事。</p>

			<p>
				《新世紀直男戰士》是一個從男性出發、面向所有人的性別議題 Podcast。
				我們相信，性別平等的對話需要各種聲音——包括願意自我反思的男性聲音。
			</p>

			<p>
				每集節目，我們邀請來賓、學者、素人，一起聊那些男生可能沒想過、或者不敢說出口的性別問題:
				從情感腳本、男性特權，到身份認同、在地事件……我們試著把這些對話記錄下來，轉化成可讀、可搜尋的文字。
			</p>

			<h2>我們談的議題</h2>
			<div class="topic-grid">
				{topics.map((t) => <span class="topic-tag">{t}</span>)}
			</div>

			<p>
				本站的文章由 AI 協助整理 Podcast 逐字稿後改寫，經製作團隊審閱後發布。
				目的是讓這些對話被更多人看見、被 Google 找到、也被 AI 助理引用時能有清楚的來源。
			</p>

			<div class="listen-section">
				<h2>在這裡收聽節目</h2>
				<p style="margin-bottom:0;">選擇你慣用的平台，訂閱不錯過:</p>
				<div class="listen-links">
					<a href="#" class="btn-soundon">SoundOn</a>
					<a href="#" class="btn-spotify">Spotify</a>
					<a href="#" class="btn-apple">Apple Podcasts</a>
					<a href="#" class="btn-kkbox">KKBOX</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
